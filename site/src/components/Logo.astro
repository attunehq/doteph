---
// The site wordmark: the same terminal-prompt-plus-dissolving-cursor glyph as
// the favicon, redrawn with CSS variables so it inherits the page's ink/teal
// rather than the favicon's fixed asset colors.
interface Props {
  size?: number;
}
const { size = 26 }: Props = Astro.props;
---

<span class="logo" style={`--logo-size:${size}px`}>
  <svg
    class="logo-mark"
    width={size}
    height={size}
    viewBox="0 0 32 32"
    aria-hidden="true"
    fill="none"
  >
    <rect class="logo-plate" width="32" height="32" rx="7" />
    <path
      class="logo-prompt"
      d="M8 11.2 13 16l-5 4.8"
      stroke-width="2.6"
      stroke-linecap="round"
      stroke-linejoin="round"
    ></path>
    <circle class="logo-dot logo-dot--1" cx="18.6" cy="20.8" r="2.1"></circle>
    <circle class="logo-dot logo-dot--2" cx="23.4" cy="20.8" r="1.5"></circle>
    <circle class="logo-dot logo-dot--3" cx="26.9" cy="20.8" r="0.9"></circle>
  </svg>
  <span class="logo-word">eph</span>
</span>

<style>
  .logo {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    color: var(--ink);
  }
  .logo-mark {
    flex: none;
  }
  .logo-plate {
    fill: var(--ink);
  }
  .logo-prompt {
    stroke: var(--ink-inverse);
    fill: none;
  }
  .logo-dot {
    fill: var(--teal);
  }
  .logo-dot--2 {
    opacity: 0.55;
  }
  .logo-dot--3 {
    opacity: 0.25;
  }
  .logo-word {
    font-family: var(--font-mono);
    font-weight: 600;
    font-size: calc(var(--logo-size) * 0.66);
    letter-spacing: -0.01em;
    color: var(--ink);
  }
</style>
