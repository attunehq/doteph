---
import Logo from "./Logo.astro";
import { withBase } from "../lib/base";

const repo = "https://github.com/attunehq/doteph";
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container footer-inner">
    <div class="footer-brand">
      <Logo size={24} />
      <p class="footer-tag">Ephemeral services per workspace.</p>
    </div>

    <nav class="footer-links" aria-label="Footer">
      <a href={withBase("/guide")}>Guide</a>
      <a href={repo} rel="noopener">GitHub</a>
      <a href={`${repo}/blob/main/LICENSE`} rel="noopener">MIT License</a>
    </nav>
  </div>

  <div class="container footer-base">
    <span>&copy; {year} Attune, Inc.</span>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--line);
    background: var(--paper-2);
    padding-block: clamp(2.5rem, 1.5rem + 3vw, 4rem) 1.5rem;
  }
  .footer-inner {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    align-items: center;
    gap: 1.5rem 2.5rem;
  }
  .footer-tag {
    margin-top: 0.75rem;
    font-size: var(--text-sm);
    color: var(--ink-3);
    max-width: 30ch;
  }

  .footer-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 1.75rem;
  }
  .footer-links a {
    font-size: var(--text-sm);
    color: var(--ink-2);
  }
  .footer-links a:hover {
    color: var(--teal-deep);
  }

  .footer-base {
    margin-top: 2.5rem;
    padding-top: 1.25rem;
    border-top: 1px solid var(--line);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--ink-3);
  }
</style>
