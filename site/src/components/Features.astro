---
import SectionHeading from "./SectionHeading.astro";

const features = [
  {
    title: "Per-workspace isolation",
    body: "Every resource eph creates is namespaced by a hash of the workspace's canonical path: eph-a1b2c3d4-postgres. Two checkouts never see each other's containers, volumes, or data.",
  },
  {
    title: "Automatic, loopback-bound ports",
    body: "You never pick a host port. eph asks Docker for a free one and binds it to 127.0.0.1, so nothing collides and nothing is exposed to the local network.",
  },
  {
    title: "Health-checked startup",
    body: "eph up waits for each service's health check to pass before returning, so the connection strings eph env prints are already good to use.",
  },
  {
    title: "Four ways to define a service",
    body: "A Docker image, a Dockerfile to build, a Compose file to delegate to, or a plain run= shell command for your own app, all in the same file.",
  },
  {
    title: "Lifecycle hooks",
    body: "pre-start, post-start, pre-stop, and post-stop run at each phase of a service's life, with eph's resolved environment injected, for migrations, seeding, and cleanup.",
  },
  {
    title: "Roles and tiers",
    body: "Tag services role=dep or role=app and eph up --role dep brings up just the backing services, ready for a prewarmed, known-good tier your app can attach to later.",
  },
  {
    title: "eph dev for your app",
    body: "Foregrounds your run= app for a preview server, with --watch to restart on source changes and clean teardown of only what it started.",
  },
  {
    title: "Runs natively everywhere",
    body: "Linux, macOS, and Windows, with the same Docker-backed services on every platform and prebuilt binaries for each.",
  },
  {
    title: "Checksum-verified updates",
    body: "eph update downloads the latest release, verifies its SHA-256 checksum, and swaps the binary in place. eph update --check just reports whether one is available.",
  },
];
---

<section class="section features" id="features">
  <div class="container">
    <SectionHeading title="Everything a per-workspace dev stack needs.">
      No orchestration platform, no shared daemon config: one file per
      workspace, one binary.
    </SectionHeading>

    <div class="features-grid">
      {
        features.map((f, i) => (
          <article class="feature-card" data-reveal style={`--reveal-delay:${(i % 3) * 70}ms`}>
            <h3>{f.title}</h3>
            <p>{f.body}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .features-grid {
    margin-top: clamp(2rem, 1rem + 3vw, 3.25rem);
    display: grid;
    gap: 1.25rem;
  }
  @media (min-width: 640px) {
    .features-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (min-width: 980px) {
    .features-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .feature-card {
    padding: clamp(1.1rem, 0.8rem + 1vw, 1.4rem);
    border: 1px solid var(--line-strong);
    border-radius: var(--radius-3);
    background: var(--paper-raised);
    transition: border-color var(--dur-1) var(--ease-out),
      box-shadow var(--dur-1) var(--ease-out);
  }
  .feature-card:hover {
    border-color: var(--ink-3);
    box-shadow: var(--shadow-1);
  }
  .feature-card h3 {
    font-size: var(--text-md);
    margin-bottom: 0.55rem;
  }
  .feature-card p {
    font-size: var(--text-sm);
    color: var(--ink-2);
  }
</style>
